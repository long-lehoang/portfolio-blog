# Notion Integration
# 1. Go to https://www.notion.so/my-integrations and create a new integration
# 2. Copy the API key here
NOTION_API_KEY=your_notion_api_key_here

# 3. Create a Notion database with these properties:
#    - Title (title)
#    - Slug (rich_text)
#    - Date (date)
#    - Description (rich_text)
#    - Tags (multi_select)
#    - Published (checkbox)
# 4. Share the database with your integration
# 5. Copy the database ID from the URL (the 32-char hex string after the workspace name)
NOTION_DATABASE_ID=your_notion_database_id_here
